# Copy this file to .env and fill in the sensitive values locally.

BUSTAG_CONDA_ENV=bustag
BUSTAG_MISSAV_PROXY=http://127.0.0.1:7897
BUSTAG_MISSAV_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36
BUSTAG_MISSAV_COOKIE=user_uuid=...; cf_clearance=...

# Production server flags (used by docker/entry.sh + bustag.app.wsgi)
BUSTAG_START_SCHEDULER=1
BUSTAG_GUNICORN_WORKERS=1
BUSTAG_GUNICORN_TIMEOUT=120
BUSTAG_PORT=8000
