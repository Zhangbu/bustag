# Copy this file to .env and fill in the sensitive values locally.

BUSTAG_CONDA_ENV=bustag
BUSTAG_MISSAV_PROXY=http://127.0.0.1:7897
BUSTAG_MISSAV_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36
BUSTAG_MISSAV_COOKIE=user_uuid=...; cf_clearance=...
BUSTAG_MISSAV_PROBE_URL=

# Production server flags (used by docker/entry.sh + bustag.app.wsgi)
BUSTAG_START_SCHEDULER=1
BUSTAG_GUNICORN_WORKERS=1
BUSTAG_GUNICORN_TIMEOUT=120
BUSTAG_PORT=8000
BUSTAG_WEB_STACK=bottle
BUSTAG_WEB_BASE_URL=http://127.0.0.1:${BUSTAG_PORT}
BUSTAG_GATE_HOST=127.0.0.1
BUSTAG_GATE_PORT=18080
BUSTAG_GATE_WAIT_SECONDS=45
BUSTAG_GATE_STACKS=bottle fastapi
BUSTAG_GATE_ALLOW_SKIP_MISSING_FASTAPI=1

# Task backend flags (default: in-process memory queue, no extra middleware required)
BUSTAG_TASK_BACKEND=memory
BUSTAG_TASK_WORKERS=2

# Migration helper flags (used by scripts/migrate.sh)
BUSTAG_MIGRATE_BACKUP_FLAG=--backup

# API observability flags
BUSTAG_API_SLOW_MS=800
